{
  "schemaVersion": 1,
  "id": "autoregear",
  "version": "${version}",
  "name": "AutoRegear",
  "description": "自动从潜影盒中获取指定物品。自动放盒，取物，打盒，捡盒",
  "authors": [
    "00011152"
  ],
  "contact": {
    "repo": "https://github.com/00011152/AutoRegear"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.addon.AutoRegearAddon"
    ]
  },
  "mixins": [
    "autoregear.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["1.21.1"],
    "meteor-client": "*"
  }
}
